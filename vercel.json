{
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist", "nodeVersion": 24 } },
    { "src": "backend/server.js", "use": "@vercel/node", "config": { "nodeVersion": 24 } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/server.js" },
    { "source": "/(.*)", "destination": "frontend/$1" }
  ]
}